{
  "name": "cc-skills-usage",
  "version": "0.0.2",
  "type": "module",
  "bin": {
    "cc-skills-usage": "./dist/cli.js"
  },
  "files": ["dist"],
  "workspaces": ["packages/*"],
  "scripts": {
    "start": "bun packages/cli/src/index.ts",
    "dev": "bun --watch packages/cli/src/index.ts",
    "build": "bun build packages/cli/src/index.ts --outfile dist/cli.js --target bun --minify",
    "lint": "bunx oxlint packages/ '!**/dist/**'",
    "lint:fix": "bunx oxlint --fix packages/ '!**/dist/**'",
    "fmt": "bunx oxfmt packages/ '!**/dist/**'",
    "fmt:check": "bunx oxfmt --check packages/ '!**/dist/**'",
    "check": "bunx oxlint packages/ '!**/dist/**' && bunx oxfmt --check packages/ '!**/dist/**'",
    "check:fix": "bunx oxlint --fix packages/ '!**/dist/**' && bunx oxfmt packages/ '!**/dist/**'",
    "typecheck": "bunx tsc -b",
    "test": "bun test"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3"
  }
}
